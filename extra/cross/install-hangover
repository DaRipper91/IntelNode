#!/bin/bash

echo "Arch Linux Edition — Installing Hangover (Latest)..."

# Ensure debtap is installed for handling .deb packages on Arch
if ! command -v debtap &> /dev/null; then
    echo "Installing debtap for .deb package conversion..."
    sudo pacman -S --noconfirm debtap
    sudo debtap -u
fi

REPO="AndreRH/hangover"
API_URL="https://api.github.com/repos/$REPO/releases/latest"

# Get latest version
latest_version=$(wget -qO- $API_URL | grep -oP '"tag_name": "\Khangover-\K([^"]+)' )

if [ -z "$latest_version" ]; then
  echo "Error: Could not retrieve latest version."
  exit 1
fi

echo "Latest version found: $latest_version"

hangover_url="https://github.com/AndreRH/hangover/releases/download/hangover-${latest_version}/hangover_${latest_version}_debian13_trixie_arm64.tar"

mkdir -p /tmp/hangover
cd /tmp/hangover

echo "Downloading Hangover..."
wget "${hangover_url}" -O hangover.tar
if [ $? -ne 0 ]; then
    echo "Download failed."
    exit 1
fi

echo "Extracting and converting package..."
tar xvf hangover.tar
# Find the .deb file inside the tar
DEB_FILE=$(ls hangover*.deb | head -n 1)

if [ -n "$DEB_FILE" ]; then
    echo "Converting $DEB_FILE to Arch package..."
    # debtap -q generates the package quietly using default answers
    debtap -q "$DEB_FILE"
    ARCH_PKG=$(ls *.pkg.tar.zst | head -n 1)
    sudo pacman -U --noconfirm "$ARCH_PKG"
else
    echo "Error: No .deb file found in archive."
    exit 1
fi

echo "Initializing Wine..."
wineboot --init

echo "Installing DXVK..."
# Assuming dxvk is also in the tar, as per original script logic
DXVK_TAR=$(ls dxvk-v*.tar.gz | head -n 1)
if [ -n "$DXVK_TAR" ]; then
    tar xvf "$DXVK_TAR"
    DXVK_DIR=$(ls -d dxvk-v*/ | head -n 1)
    mv "${DXVK_DIR}x32/"* /home/tiny/.wine/drive_c/windows/syswow64/
    mv "${DXVK_DIR}arm64ec/"* /home/tiny/.wine/drive_c/windows/system32/
fi

echo "Repairing fonts..."
regedit "Z:\\home\\tiny\\.local\\share\\tiny\\extra\\chn_fonts.reg" && wine reg delete "HKEY_LOCAL_MACHINE\\Software\\Microsoft\\Windows NT\\CurrentVersion\\FontSubstitutes" /va /f

cd /tmp
rm -rf /tmp/hangover
echo "Hangover installation complete!"
