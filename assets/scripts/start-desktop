#!/bin/bash
# start-desktop: XFCE4 Graphical Session Lifecycle Manager
# Optimizing for Mali-G925 (Tensor G5) via VirGL & Termux:X11

export DISPLAY=:4
export PULSE_SERVER=tcp:127.0.0.1:4718 # Standard Tiny Computer Pulseaudio Port

# --- 1. Socket Synchronization Protocol ---
echo "[Log] Initializing Display Sync: Waiting for Termux:X11 (Socket X4)..."
MAX_ATTEMPTS=30
ATTEMPT=0
while [ ! -S /tmp/.X11-unix/X4 ]; do
    ATTEMPT=$((ATTEMPT + 1))
    if [ $ATTEMPT -ge $MAX_ATTEMPTS ]; then
        echo "[Err] Display socket synchronization timed out after ${MAX_ATTEMPTS}s."
        echo "[Err] Ensure Termux:X11 is running and configured for Display 4."
        exit 1
    fi
    sleep 1
done
echo "[Log] Socket synchronization successful: /tmp/.X11-unix/X4 is ready."

# --- 2. Hardware Acceleration Engine (VirGL) ---
# Testing for VirGL pipe availability to determine fallback strategy.
# If virgl_test_server is running on the host, the gallium pipe should be bridged.
if [ -n "$VIRGL_ENABLE" ] || [ -S /tmp/virgl-0 ]; then
    echo "[Log] Hardware Acceleration: VirGL Engine active (Mali-G925 Passthrough)."
    export GALLIUM_DRIVER=virpipe
    export MESA_GL_VERSION_OVERRIDE=4.5
    export MESA_GLES_VERSION_OVERRIDE=3.2
    export MESA_EXTENSION_OVERRIDE="-GL_MESA_framebuffer_flip_y" # Fixes rendering orientation on some Mali drivers
else
    echo "[Warn] VirGL not detected. Falling back to LLVMpipe (Software Rasterization)."
    export GALLIUM_DRIVER=llvmpipe
fi

# --- 3. HiDPI & Mobile UX Scaling ---
# Target: 2.0x Scaling for usable touch targets on high-density displays (e.g. Pixel 10 Pro)
echo "[Log] Applying HiDPI Scaling: 2.0x Factor."
export GDK_SCALE=2
export GDK_DPI_SCALE=0.5
export QT_AUTO_SCREEN_SCALE_FACTOR=1
export QT_SCALE_FACTOR=2
export ELM_SCALE=1.5 # Elementary/Enlightenment scale fallback

# --- 4. Session D-Bus & XFCE Bootstrap ---
# Initializing user-level D-Bus session to fix xfconfd and Thunar metadata issues.
if command -v dbus-launch >/dev/null; then
    echo "[Log] Launching XFCE4 Session via DBUS Wrapper..."
    exec dbus-launch --exit-with-session startxfce4
else
    echo "[Err] dbus-launch missing. XFCE session may be degraded."
    exec startxfce4
fi
